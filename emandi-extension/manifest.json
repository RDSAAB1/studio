{
  "manifest_version": 3,
  "name": "eMandi UP Data Scraper",
  "version": "2.25",
  "description": "Scrapes and consolidates 6R print and payment details from emandi.up.gov.in",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "clipboardRead",
    "tabs"
  ],
  "host_permissions": [
    "*://emandi.up.gov.in/*",
    "*://localhost/*",
    "*://localhost:*/*",
    "*://127.0.0.1/*",
    "*://127.0.0.1:*/*",
    "*://jrmd.netlify.app/*",
    "*://*.netlify.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://emandi.up.gov.in/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://emandi.up.gov.in/*",
        "*://localhost/*",
        "*://localhost:*/*",
        "*://127.0.0.1/*",
        "*://127.0.0.1:*/*",
        "*://jrmd.netlify.app/*",
        "*://*.netlify.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://emandi.up.gov.in/*"]
    },
    {
      "resources": ["xlsx.min.js", "pdf.min.js", "pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
