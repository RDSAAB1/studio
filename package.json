{
  "name": "nextn",
  "version": "0.1.0",
  "description": "BizSuite DataFlow - Business management software",
  "author": "JRMD Software",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=8192 && next dev",
    "build": "set NODE_OPTIONS=--max-old-space-size=8192 && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "export": "next build && next export",
    "netlify-build": "npm run build",
    "electron": "cross-env ELECTRON=true next build && node scripts/prepare-standalone.js && node scripts/verify-build.js && electron .",
    "electron:dev": "concurrently \"cross-env PORT=3010 npm run dev\" \"wait-on http://localhost:3010 && cross-env ELECTRON_DEV_URL=http://localhost:3010 electron .\"",
    "electron:build": "cross-env ELECTRON=true next build && node scripts/prepare-standalone.js && node scripts/verify-build.js && electron-builder",
    "electron:build:win": "cross-env ELECTRON=true next build && node scripts/prepare-standalone.js && node scripts/verify-build.js && electron-builder --win && node scripts/copy-exe-to-dist.js",
    "electron:build:mac": "cross-env ELECTRON=true next build && node scripts/prepare-standalone.js && electron-builder --mac",
    "electron:build:linux": "cross-env ELECTRON=true next build && node scripts/prepare-standalone.js && electron-builder --linux",
    "capacitor:init": "npx cap init",
    "capacitor:add:android": "npx cap add android",
    "capacitor:sync": "npm run build && npx cap sync",
    "capacitor:open:android": "npx cap open android",
    "capacitor:build:android": "npm run build && npx cap sync && npx cap open android",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@firebase/app": "^0.14.4",
    "@headlessui/react": "^2.1.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-virtual": "^3.13.13",
    "@tremor/react": "^3.17.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.7",
    "dexie-react-hooks": "^1.1.7",
    "electron-is-dev": "^3.0.1",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.2.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^9.11.0",
    "googleapis": "^140.0.1",
    "lucide-react": "^0.475.0",
    "next": "^15.5.3",
    "nodemailer": "^7.0.11",
    "patch-package": "^8.0.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-icons": "^5.2.1",
    "recharts": "^2.15.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "wav": "^1.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^24.6.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": "18"
  }
}
