rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: Deny all access unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User data (example)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Multi-tenant: tenants, members, invite codes
    match /tenants/{tenantId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /tenantMembers/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /tenantInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    // Tenant-scoped collections: tenants/{tenantId}/{collection}/{doc}
    match /tenants/{tenantId}/{collection}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Company membership and invites (user sees only their companies)
    match /companyMembers/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /companyInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    
    // Allow authenticated users to read/write specific collections
    match /suppliers/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /customers/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /expenses/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /incomes/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /payments/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /customer_payments/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /governmentFinalizedPayments/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /accounts/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /loans/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /fund_transactions/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /banks/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /bankBranches/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /bankAccounts/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /supplierBankAccounts/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /settings/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /options/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /attendance/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /projects/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /employees/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /payroll/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /inventoryItems/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /expenseTemplates/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /ledgerAccounts/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /ledgerEntries/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /ledgerCashAccounts/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /mandiReports/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /kantaParchi/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /customerDocuments/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /manufacturingCosting/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /sync_registry/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /activityLog/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /recycleBin/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ERP multi-company structure: companies → subCompanies → seasons → collections
    // SECURITY: User can only access companies they created OR joined (companyMembers)
    match /companies/{companyId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || exists(/databases/$(database)/documents/companyMembers/$(companyId)_$(request.auth.uid)));
    }
    match /companies/{companyId}/{path=**} {
      allow read, write: if request.auth != null
        && (exists(/databases/$(database)/documents/companyMembers/$(companyId)_$(request.auth.uid))
            || get(/databases/$(database)/documents/companies/$(companyId)).data.createdBy == request.auth.uid);
    }
  }
}